---
import UiIcon from './UiIcon.astro';
import { getThemeSettings } from '../lib/theme-settings';

const { settings } = getThemeSettings();
---
<dialog
  class="bits-draft-dialog"
  id="bits-draft-dialog"
  aria-labelledby="bits-draft-title"
  data-default-author-name={settings.page.bits.defaultAuthor.name ?? ''}
  data-default-author-avatar={settings.page.bits.defaultAuthor.avatar ?? ''}
>
  <form class="bits-draft-form" data-bits-draft-form>
    <div class="bits-draft-head">
      <h2 id="bits-draft-title">
        <span class="bits-draft-title-icon" aria-hidden="true">
          <UiIcon name="pen" />
        </span>
        Thoughts
      </h2>
      <button class="bits-draft-close" type="button" data-bits-draft-close aria-label="closure">×</button>
    </div>

    <div class="bits-draft-field">
      <div class="bits-draft-field-head">
        <label for="bits-draft-content">Text content</label>
        <div class="bits-draft-toolbar" data-bits-draft-toolbar role="toolbar" aria-label="Common formats">
          <button type="button" class="bits-draft-tool" data-action="bold" data-tip="Bold" aria-label="Bold">
            <UiIcon name="bold" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="italic" data-tip="italics" aria-label="italics">
            <UiIcon name="italic" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="code" data-tip="inline code" aria-label="inline code">
            <UiIcon name="code" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="quote" data-tip="Quote" aria-label="Quote">
            <UiIcon name="quote" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="list" data-tip="list" aria-label="list">
            <UiIcon name="list" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="link" data-tip="Link" aria-label="Link">
            <UiIcon name="link" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="paragraph" data-tip="paragraph" aria-label="paragraph">
            <UiIcon name="paragraph" />
          </button>
        </div>
      </div>
      <textarea
        id="bits-draft-content"
        name="content"
        rows="6"
        required
        placeholder="write something…"
      ></textarea>
    </div>

    <div class="bits-draft-row">
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-tags" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">#</span>
          Label
        </label>
        <input id="bits-draft-tags" name="tags" type="text" inputmode="text" placeholder="Comma or space separated" />
        <div class="bits-draft-help">例：Life read / life reading</div>
      </div>
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-place" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">
            <UiIcon name="map-pin" />
          </span>
          Place（Optional）
        </label>
        <input id="bits-draft-place" name="place" type="text" inputmode="text" placeholder="For example:Shanghai" />
        <div class="bits-draft-help">generate tags inside loc:&lt;Place&gt;</div>
      </div>
    </div>

    <div class="bits-draft-stack">
      <div class="bits-draft-field">
        <div class="bits-draft-field-head bits-draft-image-head">
          <div class="bits-draft-field-title">
            <label>Insert picture（Optional）</label>
            <button class="bits-draft-image-add" type="button" data-bits-image-add>+ Add to</button>
          </div>
          <div class="bits-draft-help">Automatically read image size</div>
        </div>
        <div class="bits-draft-images" data-bits-images>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 或 https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="Remove image">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="width"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="high"
            />
          </div>
        </div>
        <template data-bits-image-template>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 或 https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="Remove image">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="width"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="high"
            />
          </div>
        </template>
      </div>

      <div class="bits-draft-status" data-bits-draft-status role="status" aria-live="polite"></div>
      <div class="bits-draft-link-row">
        <button class="bits-draft-link" type="button" data-bits-manual-open hidden>
          <span class="bits-draft-link-icon" aria-hidden="true">
            <UiIcon name="eye" />
          </span>
          <span>Preview draft</span>
          <span class="bits-draft-link-caret" aria-hidden="true">
            <UiIcon name="chevron-down" />
          </span>
        </button>
      </div>

      <div class="bits-draft-manual" data-bits-manual hidden>
        <div class="bits-draft-manual-title">Draft content（read only）</div>
        <textarea class="bits-draft-manual-textarea" data-bits-manual-textarea rows="6" readonly></textarea>
        <div class="bits-draft-manual-actions">
          <div class="bits-draft-manual-note" data-bits-manual-note></div>
          <button class="bits-draft-secondary" type="button" data-bits-manual-copy>Manual copy</button>
        </div>
      </div>

      <div class="bits-identity-bar" data-identity-bar>
        <div class="bits-identity-caption">
          <span class="bits-identity-label-icon" aria-hidden="true">
            <UiIcon name="user-circle" />
          </span>
          <span id="bits-identity-heading">author（Optional）</span>
        </div>
        <div class="bits-identity-row">
          <div class="bits-identity-controls">
            <button
              class="bits-identity-pill"
              type="button"
              data-identity-pill
              aria-controls="bits-identity-panel"
              aria-expanded="false"
            >
              <span class="bits-identity-avatar" data-identity-avatar aria-hidden="true"></span>
              <span class="bits-identity-name" data-identity-name></span>
            </button>
          </div>
          <button
            class="bits-identity-new"
            type="button"
            data-identity-new
            aria-controls="bits-identity-panel"
            aria-expanded="false"
          >
            custom author
          </button>
        </div>
      </div>

      <div
        id="bits-identity-panel"
        class="bits-identity-advanced"
        data-identity-panel
        role="group"
        aria-labelledby="bits-identity-heading"
        hidden
      >
        <div class="bits-identity-fields">
          <label class="bits-identity-label">
            <span class="bits-identity-label-title">Author name</span>
            <input type="text" name="authorName" inputmode="text" data-author-name />
          </label>
          <label class="bits-identity-label">
            <span class="bits-identity-label-row">
              <span class="bits-identity-label-title">avatar path（URL）</span>
              <span class="bits-identity-label-hint">Leave blank to use default avatar；If loading fails, the first character will be displayed.</span>
            </span>
            <input type="text" name="authorAvatar" inputmode="url" data-author-avatar />
          </label>
        </div>
        <div class="bits-identity-meta">
          <p class="bits-identity-note">
            Leave blank to use current author，This article will not be written author
          </p>
          <button type="button" class="bits-identity-reset" data-author-reset>Restore default</button>
        </div>
      </div>
    </div>

    <div class="bits-draft-footer">
      <div class="bits-draft-check">
        <input id="bits-draft-draft" name="draft" type="checkbox" />
        <label for="bits-draft-draft">Mark as draft</label>
        <span class="bits-draft-check-help">draft:on-line/Preview is not shown by default</span>
      </div>
      <div class="bits-draft-actions">
        <button class="bits-draft-primary" type="button" data-bits-draft-generate>Generate and copy</button>
        <button class="bits-draft-secondary" type="button" data-bits-draft-download>download .md</button>
      </div>
    </div>
  </form>
</dialog>
