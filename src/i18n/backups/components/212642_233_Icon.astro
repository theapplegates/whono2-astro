---
// Legacy Compatible entrance，reserved only for fork / Historical calls；New code must be changed BrandIcon、UiIcon 或 AdminIcon。
import BrandIcon from './BrandIcon.astro';
import type { SiteSocialIconKey } from '../lib/theme-settings';

type LegacyBrandIconAlias = 'x-twitter' | 'mail' | 'globe';
type LegacyBrandIconName = SiteSocialIconKey | LegacyBrandIconAlias;

type LegacyIconName =
  | 'book-open'
  | 'book-closed'
  | 'reader-exit'
  | 'rss'
  | 'moon'
  | 'sun'
  | 'search'
  | 'scan'
  | 'refresh'
  | 'copy'
  | 'pen'
  | 'bold'
  | 'italic'
  | 'code'
  | 'quote'
  | 'list'
  | 'grid-tiles'
  | 'funnel'
  | 'tag'
  | 'link'
  | 'branch-nodes'
  | 'paragraph'
  | 'map-pin'
  | 'eye'
  | 'trash'
  | 'chevron-down'
  | 'chevron-up'
  | 'user-circle'
  | 'x-mark'
  | 'github'
  | 'x'
  | 'x-twitter'
  | 'email'
  | 'mail'
  | 'weibo'
  | 'facebook'
  | 'instagram'
  | 'telegram'
  | 'mastodon'
  | 'bilibili'
  | 'youtube'
  | 'linkedin'
  | 'website'
  | 'globe'
  | 'admin-site'
  | 'admin-sidebar'
  | 'admin-home'
  | 'admin-page'
  | 'admin-code';

interface Props {
  name: LegacyIconName;
  size?: number | string;
  class?: string;
  ariaLabel?: string;
}

const {
  name,
  size,
  class: className = '',
  ariaLabel
} = Astro.props as Props;

const iconSize = size ?? 24;
const ariaHidden = ariaLabel ? undefined : 'true';
const role = ariaLabel ? 'img' : undefined;

const normalizeLegacyBrandIconName = (value: LegacyIconName): LegacyBrandIconName | null => {
  switch (value) {
    case 'github':
    case 'x':
    case 'x-twitter':
    case 'email':
    case 'mail':
    case 'weibo':
    case 'facebook':
    case 'instagram':
    case 'telegram':
    case 'mastodon':
    case 'bilibili':
    case 'youtube':
    case 'linkedin':
    case 'website':
    case 'globe':
      return value;
    default:
      return null;
  }
};

const legacyBrandIconName = normalizeLegacyBrandIconName(name);
const legacyBrandIconA11yProps = ariaLabel ? { ariaLabel } : {};

const adminIconBodies = {
  'admin-site':
    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  'admin-sidebar':
    '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/>',
  'admin-home':
    '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  'admin-page':
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
  'admin-code':
    '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>'
} as const;

const adminIconBody = Object.prototype.hasOwnProperty.call(adminIconBodies, name)
  ? adminIconBodies[name as keyof typeof adminIconBodies]
  : null;

