---
import AdminIcon from './admin/AdminIcon.astro';
import SidebarActions from './sidebar/SidebarActions.astro';
import SidebarAdminNav from './sidebar/SidebarAdminNav.astro';
import SidebarNavSwitcher from './sidebar/SidebarNavSwitcher.astro';
import SidebarPublicNav from './sidebar/SidebarPublicNav.astro';
import {
  ADMIN_ROUTES,
  getAdminRoute,
  isAdminRouteRailPathActive,
  isAdminRoutePathActive
} from '../lib/admin-console/routes';
import { createWithBase } from '../utils/format';
import { getSidebarHref, getThemeSettings, type SidebarNavId } from '../lib/theme-settings';

const {
  siteTitle = 'Whono',
  activeNavId,
  isAdminContext = false,
  isDev = false,
  allowReadingMode = true,
  adminSidebarScope = 'default'
} = Astro.props as {
  siteTitle?: string;
  activeNavId?: SidebarNavId;
  isAdminContext?: boolean;
  isDev?: boolean;
  allowReadingMode?: boolean;
  adminSidebarScope?: 'default' | 'page';
};

const ADMIN_RAIL_OVERVIEW_ICON_SIZE = 22;

const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const homeHref = withBase('/');
const rssHref = withBase('/archive/rss.xml');
const adminOverviewHref = withBase('/admin/');
const { settings } = getThemeSettings();
const quote = settings.shell.quote;
const nav = settings.shell.nav
  .filter((item) => item.visible)
  .sort((a, b) => a.order - b.order)
  .map((item) => {
    const href = withBase(getSidebarHref(item.id));
    return {
      id: item.id,
      label: item.label,
      ornament: item.ornament,
      href,
      isActive: activeNavId
        ? item.id === activeNavId
        : pathname === href || (href !== homeHref && pathname.startsWith(href))
    };
  });
const hidePublicSidebarActionsInDevAdmin = isAdminContext && isDev;
const showReaderToggle = allowReadingMode && !hidePublicSidebarActionsInDevAdmin && settings.ui.readingMode.showEntry;
const showRssLink = !hidePublicSidebarActionsInDevAdmin && settings.ui.sidebarActions.showRssLink;
const showThemeToggle = settings.ui.sidebarActions.showThemeToggle;
const showAdminEntry = !hidePublicSidebarActionsInDevAdmin
  && settings.ui.sidebarActions.showAdminEntry
  && settings.site.adminOverview.publicVisible;
const isPageScopedAdminSidebar = isAdminContext && adminSidebarScope === 'page';
const showAdminRouteRail = isAdminContext && isDev;
const showAdminNavPanels = isDev && !isPageScopedAdminSidebar;
const siteTitleLabel = `${siteTitle} front page`;
const adminOverviewRoute = getAdminRoute('overview');
const adminRailTitleLabel = adminOverviewRoute.description;
const isAdminOverviewActive = pathname === adminOverviewHref;
const adminRailRoutes = ADMIN_ROUTES.filter((route) => route.id !== 'overview');
const adminSidebarRoutes = ADMIN_ROUTES.map((route) => {
  const href = withBase(route.href);
  return {
    href,
    label: route.sidebarLabel,
    description: route.description,
    isActive: isAdminRoutePathActive(pathname, href, route.activeMatch)
  };
});
---

<aside id="site-sidebar" class="sidebar">
  <a class="sidebar__title sidebar__title--site" href={homeHref} aria-label={siteTitleLabel}>
    <span class="sidebar__title-text">{siteTitle}</span>
  </a>

  {isAdminContext ? (
    <a
      class="sidebar__title sidebar__title--admin-rail"
      href={adminOverviewHref}
      aria-label={adminRailTitleLabel}
      title={adminRailTitleLabel}
      aria-current={isAdminOverviewActive ? 'page' : undefined}
    >
      <AdminIcon name={adminOverviewRoute.sidebarIcon} size={ADMIN_RAIL_OVERVIEW_ICON_SIZE} class="icon sidebar__title-icon" />
    </a>
  ) : null}

  <div class="sidebar__quote">
    {quote.split('\n').map((line) => (
      <>
        {line}<br />
      </>
    ))}
  </div>

  {showAdminNavPanels ? (
    <div class="sidebar-nav-panels" data-admin-sidebar-nav>
      <div class="sidebar-nav-stage" data-admin-nav-stage>
        <SidebarPublicNav items={nav} isAdminNavPanel />
        <SidebarAdminNav items={adminSidebarRoutes} />
      </div>
      <div class="sidebar-nav-switcher-item">
        <SidebarNavSwitcher />
      </div>
    </div>
  ) : (
    !isPageScopedAdminSidebar ? <SidebarPublicNav items={nav} /> : null
  )}

  {showAdminRouteRail ? (
    <nav class="admin-rail-routes" aria-label="Backend page">
      {adminRailRoutes.map((route) => {
        const href = withBase(route.href);
        const isActive = isAdminRouteRailPathActive(pathname, href);
        return (
          <a
            class="icon-button admin-rail-route"
            href={href}
            aria-label={`${route.sidebarLabel}：${route.description}`}
            aria-current={isActive ? 'page' : undefined}
            title={`${route.sidebarLabel}：${route.description}`}
          >
            <AdminIcon name={route.sidebarIcon} class="icon" />
          </a>
        );
      })}
    </nav>
  ) : null}

  <SidebarActions
    isAdminContext={isAdminContext}
    isDev={isDev}
    navItems={nav}
    homeHref={homeHref}
    rssHref={rssHref}
    adminOverviewHref={adminOverviewHref}
    showReaderToggle={showReaderToggle}
    showRssLink={showRssLink}
    showThemeToggle={showThemeToggle}
    showAdminEntry={showAdminEntry}
  />
</aside>
