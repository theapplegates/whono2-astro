---
import AdminIcon from './AdminIcon.astro';
import AdminHelpTip from './AdminHelpTip.astro';
import {
  ADMIN_HERO_IMAGE_ALT_DEFAULT,
  ADMIN_HERO_IMAGE_ALT_MAX_LENGTH,
  ADMIN_HOME_INTRO_LINK_DEFAULT,
  ADMIN_HOME_INTRO_LINK_OPTIONS
} from '../../lib/admin-console/theme-shared';
import defaultHero from '../../assets/hero.png';

interface Props {
  homeIntroMaxLength: number;
}

const { homeIntroMaxLength } = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-home" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">Home page settings</span>
      <span class="admin-group__legend-en">Home</span>
    </span>
  </legend>
  <div class="admin-grid">
    <div class="admin-field admin-field--full">
      <div class="admin-hero-image">
        <div class="admin-hero-fields">
          <div class="admin-field">
            <div class="admin-label admin-label--split">
              <span class="admin-label__copy">
                <label class="admin-label__main" for="home-hero-image-src">Hero Image address</label>
                <AdminHelpTip
                  id="home-hero-image-src-tip"
                  label="Hero Image address description"
                  text="support src/assets/**、public/** 或 https:// Picture bed link；Fallback to the built-in default image when the address is left blank。"
                />
              </span>
              <label class="admin-label__toggle" for="home-show-hero">
                <input id="home-show-hero" type="checkbox" checked />
                <span>exhibit</span>
              </label>
            </div>
            <div class="admin-images-field-input">
              <input
                class="admin-field__control"
                id="home-hero-image-src"
                type="text"
                inputmode="url"
                spellcheck="false"
                placeholder="currently in use：src/assets/hero.png"
                aria-label="Hero Image address"
                aria-describedby="home-hero-image-src-tip"
              />
              <button
                class="admin-btn admin-btn--ghost"
                type="button"
                data-admin-images-open="home.heroImageSrc"
                aria-label="Select local Hero picture"
              >
                choose
              </button>
            </div>
            <p class="admin-help admin-help--inline" data-admin-images-meta="home.heroImageSrc" hidden></p>
          </div>
          <div class="admin-field">
            <span class="admin-label">
              <label class="admin-label__main" for="home-hero-image-alt">Hero Image description</label>
              <span class="admin-label__hint">（Used for image alt text，Not displayed on the page）</span>
            </span>
            <input
              class="admin-field__control"
              id="home-hero-image-alt"
              type="text"
              maxlength={ADMIN_HERO_IMAGE_ALT_MAX_LENGTH}
              placeholder={ADMIN_HERO_IMAGE_ALT_DEFAULT}
              aria-label="Hero Image description"
            />
          </div>
        </div>
        <div class="admin-hero-image__preview" aria-label="Hero Picture preview">
          <p class="admin-images-field-preview-label">Preview picture</p>
          <div
            class="admin-images-field-preview admin-images-field-preview--hero"
            data-admin-images-preview="home.heroImageSrc"
            data-admin-images-default-preview-src={defaultHero.src}
            hidden
          >
            <img alt="" loading="lazy" decoding="async" data-admin-images-preview-img="home.heroImageSrc" />
            <span class="admin-images-field-placeholder" data-admin-images-preview-placeholder="home.heroImageSrc" hidden>
              front page Hero Figure is not enabled
            </span>
          </div>
        </div>
      </div>
    </div>
    <div class="admin-field admin-field--full">
      <div class="admin-label admin-label--split">
        <span class="admin-label__copy">
          <label class="admin-label__main" for="home-intro-lead">Home page introduction main copy</label>
        </span>
        <label class="admin-label__toggle" for="home-show-intro-lead">
          <input id="home-show-intro-lead" type="checkbox" checked />
          <span>exhibit</span>
        </label>
      </div>
      <textarea class="admin-field__control admin-field__control--compact-textarea" id="home-intro-lead" rows="2" maxlength={homeIntroMaxLength}></textarea>
    </div>
    <div class="admin-field admin-field--full">
      <div class="admin-label admin-label--split">
        <span class="admin-label__copy">
          <label class="admin-label__main" for="home-intro-more">Home page introduction supplementary copy</label>
          <span class="admin-label__hint">（Fixed sentence pattern：Supplementary copy + Link + Optional“或” + Link）</span>
        </span>
        <label class="admin-label__toggle" for="home-show-intro-more">
          <input id="home-show-intro-more" type="checkbox" checked />
          <span>exhibit</span>
        </label>
      </div>
      <div class="admin-inline-builder admin-inline-builder--intro-more" role="group" aria-label="Home page introduction supplementary sentence editor">
        <textarea
          id="home-intro-more"
          class="admin-field__control admin-inline-builder__text"
          rows="1"
          maxlength={homeIntroMaxLength}
          aria-label="Home page introduction supplementary copy"
        ></textarea>
        <span class="admin-inline-builder__select-group">
          <select
            id="home-intro-more-link-primary"
            class="admin-field__control admin-inline-builder__select"
            aria-label="Home page introduction supplements the main link"
          >
            {ADMIN_HOME_INTRO_LINK_OPTIONS.map((option) => (
              <option value={option.id} selected={option.id === ADMIN_HOME_INTRO_LINK_DEFAULT[0]}>
                {option.label}
              </option>
            ))}
          </select>
        </span>
        <span class="admin-inline-builder__divider" aria-hidden="true">|</span>
        <label class="admin-inline-builder__toggle" for="home-intro-more-link-secondary-enabled">
          <input
            id="home-intro-more-link-secondary-enabled"
            type="checkbox"
            aria-controls="home-intro-more-link-secondary"
          />
          <span>Enable dual linking</span>
        </label>
        <span
          id="home-intro-more-link-secondary-group"
          class="admin-inline-builder__secondary"
          aria-disabled="true"
        >
          <span class="admin-inline-builder__secondary-sep">或</span>
          <select
            id="home-intro-more-link-secondary"
            class="admin-field__control admin-inline-builder__select"
            aria-label="Home page introduction supplements the second link"
            disabled
          >
            {ADMIN_HOME_INTRO_LINK_OPTIONS.map((option) => (
              <option value={option.id} selected={option.id === ADMIN_HOME_INTRO_LINK_DEFAULT[1]}>
                {option.label}
              </option>
            ))}
          </select>
        </span>
      </div>
      <p class="admin-help">
        Supplementary introduction preview：<code id="home-intro-more-preview" class="admin-help__preview-value">For more articles please visit Archive。</code>
      </p>
    </div>
  </div>
</fieldset>
