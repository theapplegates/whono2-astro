---
import { ADMIN_ROUTES, type AdminRouteId } from '../../lib/admin-console/routes';
import { createWithBase } from '../../utils/format';

const { currentRoute } = Astro.props as {
  currentRoute: AdminRouteId;
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
---

<nav class="admin-route-nav" aria-label="Backend navigation">
  <ul class="admin-route-nav__list">
    {
      ADMIN_ROUTES.map((route) => {
        const isActive = route.id === currentRoute;
        return (
          <li class="admin-route-nav__item">
            <a
              href={withBase(route.href)}
              class:list={['admin-route-nav__link', isActive && 'is-active']}
              aria-current={isActive ? 'page' : undefined}
              data-admin-nav-link
              title={route.description}
            >
              <span class="admin-route-nav__label">{route.label}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
