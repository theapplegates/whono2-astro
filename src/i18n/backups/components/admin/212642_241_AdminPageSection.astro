---
import AdminIcon from './AdminIcon.astro';
import AdminHelpTip from './AdminHelpTip.astro';
import { ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH } from '../../lib/admin-console/theme-shared';

interface Props {
  pageTitleMaxLength: number;
  pageSubtitleMaxLength: number;
  memoTitlePlaceholder?: string;
  memoSubtitlePlaceholder?: string;
}

const {
  pageTitleMaxLength,
  pageSubtitleMaxLength,
  memoTitlePlaceholder = '',
  memoSubtitlePlaceholder = ''
} = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-page" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">Inner page settings</span>
      <span class="admin-group__legend-en">Inner pages</span>
    </span>
  </legend>
  <div class="admin-grid">
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/essay/</code> Page owner <span class="admin-label__pipe" aria-hidden="true">|</span> subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/essay/ Page main title and subtitle">
        <input
          id="page-essay-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Essay"
          aria-label="/essay/ Page main title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-essay-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Essays and Miscellaneous Notes"
          aria-label="/essay/ Page subtitle"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/bits/</code> Page owner <span class="admin-label__pipe" aria-hidden="true">|</span> subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/bits/ Page main title and subtitle">
        <input
          id="page-bits-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Whisper"
          aria-label="/bits/ Page main title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-bits-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Life is not just a novel"
          aria-label="/bits/ Page subtitle"
        />
      </span>
    </label>
    <div class="admin-field admin-field--full admin-field--memo">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/memo/</code> Page owner <span class="admin-label__pipe" aria-hidden="true">|</span> subtitle
        </span>
        <AdminHelpTip
          id="page-memo-title-tip"
          label="/memo/ Page title description"
          text="After filling in, overwrite the corresponding fields.，Leave blank to use src/content/memo/index.md。"
        />
      </span>
      <span class="admin-title-pair" role="group" aria-label="/memo/ Page main title and subtitle">
        <input
          id="page-memo-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder={memoTitlePlaceholder || undefined}
          aria-label="/memo/ Page main title"
          aria-describedby="page-memo-title-tip"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-memo-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder={memoSubtitlePlaceholder || undefined}
          aria-label="/memo/ Page subtitle"
          aria-describedby="page-memo-title-tip"
        />
      </span>
    </div>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/archive/</code> Page owner <span class="admin-label__pipe" aria-hidden="true">|</span> subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/archive/ Page main title and subtitle">
        <input
          id="page-archive-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Archive"
          aria-label="/archive/ Page main title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-archive-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Archive directory grouped by year"
          aria-label="/archive/ Page subtitle"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/about/</code> Page owner <span class="admin-label__pipe" aria-hidden="true">|</span> subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/about/ Page main title and subtitle">
        <input
          id="page-about-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="about"
          aria-label="/about/ Page main title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-about-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          aria-label="/about/ Page subtitle"
        />
      </span>
    </label>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">Article meta information</span>
      <span class="admin-subtitle__hint">（word count/Duration only details page，Hide on mobile）</span>
    </p>
    <div class="admin-toggle-row-group admin-toggle-row-group--article-meta">
      <div class="admin-toggle-row admin-toggle-row--with-inline-field">
        <label class="admin-toggle-row admin-toggle-row--compact" for="ui-article-meta-show-date">
          <input id="ui-article-meta-show-date" type="checkbox" />
          <span>Show release date</span>
        </label>
        <span class="admin-toggle-row__sep" aria-hidden="true">|</span>
        <label class="admin-inline-field" for="ui-article-meta-date-label">
          <span class="admin-inline-field__label">prefix：</span>
          <input
            id="ui-article-meta-date-label"
            class="admin-inline-field__input"
            type="text"
            maxlength={ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH}
            autocomplete="off"
            placeholder="Posted in："
          />
        </label>
      </div>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-tags" type="checkbox" />
        <span>Show label</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-word-count" type="checkbox" />
        <span>Display word count</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-reading-time" type="checkbox" />
        <span>Show reading time</span>
      </label>
    </div>
    <p class="admin-help admin-help--article-meta-preview">
      Preview：<code id="article-meta-preview-value" class="admin-help__preview-value">{'Posted in：2026-03-18 · #Astro\u00A0\u00A0#writing · 共 2,416 字 · 约 6 minute'}</code>
    </p>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">/bits/Page default author</span>
    </p>
    <div class="admin-author-image">
      <div class="admin-author-image__fields">
        <label class="admin-field">
          <span class="admin-label">
            <span class="admin-label__main">Default author name</span>
          </span>
          <input class="admin-field__control" id="page-bits-author-name" type="text" autocomplete="off" />
        </label>
        <div class="admin-field">
          <span class="admin-label">
            <label class="admin-label__main" for="page-bits-author-avatar">Default avatar</label>
            <span class="admin-label__hint">（relative path）</span>
          </span>
          <div class="admin-images-field-input">
            <input class="admin-field__control" id="page-bits-author-avatar" type="text" autocomplete="off" />
            <button
              class="admin-btn admin-btn--ghost"
              type="button"
              data-admin-images-open="page.bits.defaultAuthor.avatar"
              aria-label="choose Bits Default avatar"
            >
              choose
            </button>
          </div>
        </div>
      </div>
      <div class="admin-author-image__preview" aria-label="Default avatar preview">
        <p class="admin-images-field-preview-label">Preview avatar</p>
        <div
          class="admin-images-field-preview admin-images-field-preview--avatar"
          data-admin-images-preview="page.bits.defaultAuthor.avatar"
          hidden
        >
          <img alt="" loading="lazy" decoding="async" data-admin-images-preview-img="page.bits.defaultAuthor.avatar" />
        </div>
      </div>
    </div>
  </div>
</fieldset>
