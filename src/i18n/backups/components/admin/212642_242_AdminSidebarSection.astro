---
import AdminHelpTip from './AdminHelpTip.astro';
import AdminIcon from './AdminIcon.astro';
import UiIcon from '../UiIcon.astro';
import type { SidebarNavId } from '../../lib/theme-settings';
import {
  ADMIN_NAV_ORNAMENT_DEFAULT,
  ADMIN_NAV_ORNAMENT_MAX_LENGTH,
  ADMIN_SIDEBAR_DIVIDER_OPTIONS
} from '../../lib/admin-console/theme-shared';

interface Props {
  navIdOrder: readonly SidebarNavId[];
}

const { navIdOrder } = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-sidebar" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">Sidebar settings</span>
      <span class="admin-group__legend-en">Sidebar</span>
    </span>
  </legend>
  <div class="admin-sidebar-layout">
    <div class="admin-sidebar-layout__main">
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">Sidebar site name</span>
          <span class="admin-label__hint">（Display the site title on the left）</span>
        </span>
        <input class="admin-field__control" id="shell-brand-title" type="text" autocomplete="off" />
      </label>
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">Sidebar quote copy</span>
          <span class="admin-label__hint">（Support line wrap display）</span>
        </span>
        <textarea class="admin-field__control" id="shell-quote" rows="4"></textarea>
      </label>
      <div class="admin-field admin-field--sidebar-divider">
        <span class="admin-label">
          <span class="admin-label__main">sidebar divider</span>
          <span class="admin-label__hint">（Control the strength of the separation from the main text）</span>
        </span>
        <div class="admin-segmented" role="radiogroup" aria-label="Sidebar divider style">
          {
            ADMIN_SIDEBAR_DIVIDER_OPTIONS.map((option) => (
              <label class="admin-segmented__option" for={`ui-layout-sidebar-divider-${option.id}`}>
                <input
                  id={`ui-layout-sidebar-divider-${option.id}`}
                  name="ui-layout-sidebar-divider"
                  type="radio"
                  value={option.id}
                  checked={option.id === 'default'}
                />
                <span>{option.label}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="admin-subgroup admin-subgroup--sidebar-icons">
        <p class="admin-subtitle">
          <span class="admin-subtitle__main">Sidebar icon</span>
          <span class="admin-subtitle__hint">（Select the icon shown at the bottom）</span>
        </p>
        <div class="admin-sidebar-icon-grid" role="group" aria-label="Show and hide sidebar icons">
          <label class="admin-sidebar-icon-toggle" for="ui-reading-entry" title="Show reading mode entry">
            <input id="ui-reading-entry" type="checkbox" aria-label="Show reading mode entry" title="Show reading mode entry" />
            <span
              class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-sidebar-icon-toggle__button"
              aria-hidden="true"
            >
              <UiIcon name="book-open" size={18} strokeWidth={2} />
            </span>
          </label>
          <label class="admin-sidebar-icon-toggle" for="ui-sidebar-actions-show-rss-link" title="show RSS Entrance">
            <input
              id="ui-sidebar-actions-show-rss-link"
              type="checkbox"
              aria-label="show RSS Entrance"
              title="show RSS Entrance"
            />
            <span
              class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-sidebar-icon-toggle__button"
              aria-hidden="true"
            >
              <UiIcon name="rss" size={18} strokeWidth={2} />
            </span>
          </label>
          <label class="admin-sidebar-icon-toggle" for="ui-sidebar-actions-show-theme-toggle" title="Show theme switching entrance">
            <input
              id="ui-sidebar-actions-show-theme-toggle"
              type="checkbox"
              aria-label="Show theme switching entrance"
              title="Show theme switching entrance"
            />
            <span
              class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-sidebar-icon-toggle__button"
              aria-hidden="true"
            >
              <UiIcon name="moon" size={17} strokeWidth={2} />
            </span>
          </label>
          <label
            id="ui-sidebar-actions-show-admin-entry-row"
            class="admin-sidebar-icon-toggle"
            for="ui-sidebar-actions-show-admin-entry"
            title="Show site overview portal（/admin/）"
          >
            <input
              id="ui-sidebar-actions-show-admin-entry"
              type="checkbox"
              aria-label="show /admin/ Entrance"
              title="Show site overview portal（/admin/）"
            />
            <span
              class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-sidebar-icon-toggle__button"
              aria-hidden="true"
            >
              <UiIcon name="monitor-dot" size={18} strokeWidth={2} />
            </span>
          </label>
        </div>
      </div>
    </div>

    <div class="admin-subgroup admin-subgroup--sidebar-nav">
      <p class="admin-subtitle">
        <span class="admin-subtitle__main">Sidebar navigation</span>
        <AdminHelpTip
          id="admin-nav-ornament-hint"
          label="Sidebar navigation suffix description"
          text={`Suffix supports short text/symbol；Leave blank to hide，enter ${ADMIN_NAV_ORNAMENT_DEFAULT} Restore default。`}
        />
      </p>
      <div class="admin-nav-grid admin-nav-grid--compact">
        <div class="admin-nav-header" aria-hidden="true">
          <span>sort</span>
          <span>page ID</span>
          <span>Navigation name</span>
          <span>Navigation suffix</span>
          <span>Whether to display</span>
        </div>
        {
          navIdOrder.map((id, index) => (
            <div class="admin-row admin-row--interactive admin-row--table admin-nav-row" data-nav-id={id}>
              <label class="admin-field admin-nav-field admin-nav-field--order">
                <span class="admin-nav-cell-label">sort</span>
                <span class="sr-only">{id} sort</span>
                <span class="admin-social-order-frame admin-nav-order-frame">
                  <span class="admin-social-order-frame__mark" aria-hidden="true">[</span>
                  <input
                    class="admin-field__control"
                    data-nav-field="order"
                    name={`shell-nav-${id}-order`}
                    type="number"
                    min="1"
                    step="1"
                    inputmode="numeric"
                    value={index + 1}
                  />
                  <span class="admin-social-order-frame__mark" aria-hidden="true">]</span>
                </span>
              </label>
              <p class="admin-nav-id">
                <span class="admin-nav-cell-label">page ID</span>
                <span class="admin-nav-id__text">{id}</span>
              </p>
              <label class="admin-field admin-nav-field admin-nav-field--name">
                <span class="admin-nav-cell-label">Navigation name</span>
                <span class="sr-only">{id} Navigation name</span>
                <input
                  class="admin-field__control admin-field__control--soft"
                  data-nav-field="label"
                  name={`shell-nav-${id}-label`}
                  type="text"
                  autocomplete="off"
                />
              </label>
              <label class="admin-field admin-nav-field admin-nav-field--ornament">
                <span class="admin-nav-cell-label">Navigation suffix</span>
                <span class="sr-only">{id} Navigation suffix，Leave blank to not display</span>
                <input
                  class="admin-field__control admin-field__control--soft"
                  data-nav-field="ornament"
                  name={`shell-nav-${id}-ornament`}
                  type="text"
                  autocomplete="off"
                  maxlength={ADMIN_NAV_ORNAMENT_MAX_LENGTH}
                  aria-describedby="admin-nav-ornament-hint"
                />
              </label>
              <label class="admin-toggle">
                <span class="admin-nav-cell-label">Whether to display</span>
                <span class="admin-toggle__control">
                  <input
                    data-nav-field="visible"
                    name={`shell-nav-${id}-visible`}
                    type="checkbox"
                    aria-label={`${id} Whether to display`}
                  />
                </span>
              </label>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</fieldset>
