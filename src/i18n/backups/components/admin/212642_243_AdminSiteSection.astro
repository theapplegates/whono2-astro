---
import AdminIcon from './AdminIcon.astro';
import AdminSiteSocialSection from './AdminSiteSocialSection.astro';
import { ADMIN_OVERVIEW_HIDDEN_MESSAGE_MAX_LENGTH } from '../../lib/admin-console/theme-shared';

interface Props {
  footerStartYearMin: number;
  footerStartYearMax: number;
  socialCustomLimit: number;
}

const { footerStartYearMin, footerStartYearMax, socialCustomLimit } = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-site" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">Site settings</span>
      <span class="admin-group__legend-en">Site</span>
    </span>
  </legend>
  <div class="admin-grid">
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">site title</span>
        <span class="admin-label__hint">（for browser title / RSS / share）</span>
      </span>
      <input class="admin-field__control" id="site-title" type="text" autocomplete="off" />
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">site language</span>
        <span class="admin-label__hint">（The default value is zh-CN）</span>
      </span>
      <input class="admin-field__control" id="site-default-locale" type="text" autocomplete="off" />
    </label>
    <label class="admin-field admin-field--full">
      <span class="admin-label">
        <span class="admin-label__main">default SEO describe</span>
        <span class="admin-label__hint">（Used to search results and share snippets）</span>
      </span>
      <textarea class="admin-field__control admin-field__control--singleline-textarea" id="site-description" rows="1"></textarea>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">footer year</span>
        <span class="admin-label__hint">（The end year automatically picks up the current year）</span>
      </span>
      <span class="admin-year-range">
        <input
          class="admin-field__control"
          id="site-footer-start-year"
          type="number"
          min={footerStartYearMin}
          max={footerStartYearMax}
          step="1"
          inputmode="numeric"
          placeholder={String(footerStartYearMax)}
          aria-describedby="site-footer-preview"
        />
        <span class="admin-year-range__sep" aria-hidden="true">-</span>
        <input
          class="admin-field__control admin-year-range__readonly"
          name="site-footer-current-year-display"
          type="text"
          value={String(footerStartYearMax)}
          readonly
          tabindex="-1"
          aria-label="current year（automatic）"
        />
        <label class="admin-year-range__toggle">
          <input id="site-footer-show-current-year" type="checkbox" checked />
          <span class="sr-only">Show current year</span>
        </label>
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">Footer copyright copy</span>
      </span>
      <input class="admin-field__control" id="site-footer-copyright" type="text" autocomplete="off" aria-describedby="site-footer-preview" />
    </label>
    <div class="admin-field admin-field--full">
      <p id="site-footer-preview" class="admin-help">
        Footer preview：<code id="site-footer-preview-value">© {footerStartYearMax} Whono · Theme Demo · by cxro</code>
      </p>
    </div>
    <div class="admin-field admin-field--full">
      <div class="admin-label admin-label--split">
        <span class="admin-label__copy">
          <label class="admin-label__main" for="site-admin-overview-hidden-message">
            <code>/admin/</code> Overview public access（Not included）
          </label>
          <span class="admin-label__hint">（Effective after build；When public is closed，This page only displays the text below）</span>
        </span>
        <label class="admin-label__toggle" for="site-admin-overview-public-visible">
          <input id="site-admin-overview-public-visible" type="checkbox" checked />
          <span>public</span>
        </label>
      </div>
      <input
        class="admin-field__control"
        id="site-admin-overview-hidden-message"
        type="text"
        maxlength={ADMIN_OVERVIEW_HIDDEN_MESSAGE_MAX_LENGTH}
        autocomplete="off"
        disabled
      />
    </div>
  </div>

  <AdminSiteSocialSection socialCustomLimit={socialCustomLimit} />
</fieldset>
